# Credenciais do Mailchimp para o emulador local de Firebase Functions.
# Copie este arquivo para .secret.local e preencha com seus valores reais.
#
# Para obter essas credenciais:
# 1. Acesse https://mailchimp.com → Account → Extras → API keys
# 2. O server prefix é o sufixo da URL da API (ex: us1, us2, etc.)
# 3. O audience ID está em Audience → Settings → Audience name and defaults

MAILCHIMP_API_KEY=your-mailchimp-api-key-here
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=your-audience-id-here
