    "mailchimp-api-v3": "^1.15.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/mailchimp-api-v3": "^1.14.0",
    "ts-node": "^10.9.0"
  },
  "private": true
