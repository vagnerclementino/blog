{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": [
    "src",
    "content",
    "gatsby-*.ts",
    "gulpfile.ts",
    "**/*.d.ts"
  ],
  "exclude": ["node_modules", "build", "tsbuildinfo", ".cache"],
  "types": ["node"]
}